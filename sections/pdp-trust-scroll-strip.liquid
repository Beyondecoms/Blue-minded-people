{%- liquid
  assign section_id = 'pdp-trust-strip-' | append: section.id
-%}

<div
  id="{{ section_id }}"
  class="pdp-trust-scroll-strip{% if section.settings.border_enable %} pdp-trust-scroll-strip--bordered{% endif %}"
  style="
    --section-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --section-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --gap: {{ section.settings.gap }}px;
    --scroll-speed: {{ section.settings.scroll_speed }}s;
    --font-size-desktop: {{ section.settings.font_size_desktop }}px;
    --font-size-mobile: {{ section.settings.font_size_mobile }}px;
    --font-weight: {{ section.settings.font_weight }};
    --text-color: {{ section.settings.text_color }};
    --icon-color: {{ section.settings.icon_color }};
    --icon-size: {{ section.settings.icon_size }}px;
    --divider-color: {{ section.settings.divider_color }};
    --bg-color: {{ section.settings.bg_color }};
    --border-color: {{ section.settings.border_color }};
  "
>
  <div class="pdp-trust-scroll-strip__track">
    {%- comment -%} Repeat 4 times to ensure seamless infinite looping on all screen sizes {%- endcomment -%}
    {%- for i in (1..4) -%}
      <div
        class="pdp-trust-scroll-strip__set pdp-trust-scroll-strip__set--{{ section.settings.scroll_direction }}"
        {% if i > 1 %}aria-hidden="true"{% endif %}
      >
        {%- for block in section.blocks -%}
          <div class="pdp-trust-scroll-strip__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_svg != blank -%}
              <div class="pdp-trust-scroll-strip__icon">
                {{ block.settings.icon_svg }}
              </div>
            {%- elsif block.settings.icon_image != blank -%}
              <div class="pdp-trust-scroll-strip__icon">
                {{ block.settings.icon_image | image_url: width: 60 | image_tag: class: 'pdp-trust-scroll-strip__icon-img', loading: 'lazy', alt: block.settings.text }}
              </div>
            {%- endif -%}
            <span class="pdp-trust-scroll-strip__label">{{ block.settings.text }}</span>
          </div>
          <span class="pdp-trust-scroll-strip__divider pdp-trust-scroll-strip__divider--{{ section.settings.divider_style }}" aria-hidden="true"></span>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
.pdp-trust-scroll-strip {
  width: 100%;
  overflow: hidden;
  background-color: var(--bg-color);
  font-family: var(--font-body, var(--font-body--family, "Inter", sans-serif));
  font-weight: var(--font-weight);
  letter-spacing: 0.5px;
  color: var(--text-color);
  box-sizing: border-box;
  padding-top: var(--section-padding-top-mobile);
  padding-bottom: var(--section-padding-bottom-mobile);
}

.pdp-trust-scroll-strip--bordered {
  border-top: 1px solid var(--border-color);
  border-bottom: 1px solid var(--border-color);
}

@media screen and (min-width: 750px) {
  .pdp-trust-scroll-strip {
    padding-top: var(--section-padding-top-desktop);
    padding-bottom: var(--section-padding-bottom-desktop);
  }
}

.pdp-trust-scroll-strip__track {
  display: flex;
  width: max-content;
}

.pdp-trust-scroll-strip__set {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: var(--gap);
  padding-right: var(--gap);
}

/* Scroll Direction Animation classes */
.pdp-trust-scroll-strip__set--left {
  animation: pdp-scroll-left var(--scroll-speed) linear infinite;
}

.pdp-trust-scroll-strip__set--right {
  animation: pdp-scroll-right var(--scroll-speed) linear infinite;
}

/* Pause animation on hover (desktop/hover-capable only) */
@media screen and (min-width: 750px) {
  .pdp-trust-scroll-strip:hover .pdp-trust-scroll-strip__set {
    animation-play-state: paused;
  }
}

.pdp-trust-scroll-strip__item {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.pdp-trust-scroll-strip__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--icon-size);
  height: var(--icon-size);
  color: var(--icon-color);
  flex-shrink: 0;
}

.pdp-trust-scroll-strip__icon svg {
  display: block;
  width: 100%;
  height: 100%;
  fill: none;
  stroke: currentColor;
  stroke-width: var(--icon-stroke-width, 1.5px);
}

.pdp-trust-scroll-strip__icon img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.pdp-trust-scroll-strip__label {
  font-size: var(--font-size-mobile);
  line-height: 1.2;
  white-space: nowrap;
}

@media screen and (min-width: 750px) {
  .pdp-trust-scroll-strip__label {
    font-size: var(--font-size-desktop);
  }
}

.pdp-trust-scroll-strip__divider {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--divider-color);
  flex-shrink: 0;
  user-select: none;
}

/* Divider Styles */
.pdp-trust-scroll-strip__divider--line::after {
  content: "";
  display: block;
  width: 1px;
  height: 14px;
  background-color: var(--divider-color);
}

.pdp-trust-scroll-strip__divider--dot::after {
  content: "•";
}

.pdp-trust-scroll-strip__divider--icon-based::after {
  content: "⊕";
}

@keyframes pdp-scroll-left {
  0% {
    transform: translate3d(0, 0, 0);
  }
  100% {
    transform: translate3d(-100%, 0, 0);
  }
}

@keyframes pdp-scroll-right {
  0% {
    transform: translate3d(-100%, 0, 0);
  }
  100% {
    transform: translate3d(0, 0, 0);
  }
}
</style>


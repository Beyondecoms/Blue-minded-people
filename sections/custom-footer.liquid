{% liquid
  assign customer_care_heading = section.settings.customer_care_heading | strip
  assign about_heading = section.settings.about_heading | strip
  assign app_heading = section.settings.app_heading | strip
  assign payments_heading = section.settings.payments_heading | strip
  assign brand_heading = section.settings.brand_heading | strip
  assign brand_description = section.settings.brand_description
  assign copyright_text = section.settings.copyright_text | strip
%}

<section
  id="CustomFooter-{{ section.id }}"
  class="custom-footer"
  style="
    --custom-footer-background: {{ section.settings.background_color }};
    --custom-footer-text: {{ section.settings.text_color }};
    --custom-footer-heading: {{ section.settings.heading_color }};
    --custom-footer-link: {{ section.settings.link_color }};
    --custom-footer-link-hover: {{ section.settings.link_hover_color }};
    --custom-footer-heading-size: {{ section.settings.heading_font_size }}px;
    --custom-footer-menu-size: {{ section.settings.menu_font_size }}px;
    --custom-footer-description-size: {{ section.settings.description_font_size }}px;
    --custom-footer-copyright-size: {{ section.settings.copyright_font_size }}px;
    --custom-footer-top-padding: {{ section.settings.padding_top }}px;
    --custom-footer-bottom-padding: {{ section.settings.padding_bottom }}px;
    --custom-footer-column-gap: {{ section.settings.desktop_column_gap }}px;
    --custom-footer-mobile-gap: {{ section.settings.mobile_column_gap }}px;
    --custom-footer-logo-width: {{ section.settings.logo_width }}px;
    --custom-footer-qr-width: {{ section.settings.qr_width }}px;
  "
>
  <div class="custom-footer__inner section section--full-width">
    <div class="custom-footer__grid">
      <div class="custom-footer__column">
        {% if customer_care_heading != blank %}
          <h2 class="custom-footer__heading">{{ customer_care_heading }}</h2>
        {% endif %}
        <nav
          class="custom-footer__nav"
          aria-label="{{ customer_care_heading | escape }}"
        >
          <ul class="custom-footer__menu" role="list">
            {% if section.settings.customer_care_label_1 != blank %}
              <li><a href="{{ section.settings.customer_care_url_1 | default: '#' }}">{{ section.settings.customer_care_label_1 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_2 != blank %}
              <li><a href="{{ section.settings.customer_care_url_2 | default: '#' }}">{{ section.settings.customer_care_label_2 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_3 != blank %}
              <li><a href="{{ section.settings.customer_care_url_3 | default: '#' }}">{{ section.settings.customer_care_label_3 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_4 != blank %}
              <li><a href="{{ section.settings.customer_care_url_4 | default: '#' }}">{{ section.settings.customer_care_label_4 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_5 != blank %}
              <li><a href="{{ section.settings.customer_care_url_5 | default: '#' }}">{{ section.settings.customer_care_label_5 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_6 != blank %}
              <li><a href="{{ section.settings.customer_care_url_6 | default: '#' }}">{{ section.settings.customer_care_label_6 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_7 != blank %}
              <li><a href="{{ section.settings.customer_care_url_7 | default: '#' }}">{{ section.settings.customer_care_label_7 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_8 != blank %}
              <li><a href="{{ section.settings.customer_care_url_8 | default: '#' }}">{{ section.settings.customer_care_label_8 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_9 != blank %}
              <li><a href="{{ section.settings.customer_care_url_9 | default: '#' }}">{{ section.settings.customer_care_label_9 }}</a></li>
            {% endif %}
            {% if section.settings.customer_care_label_10 != blank %}
              <li><a href="{{ section.settings.customer_care_url_10 | default: '#' }}">{{ section.settings.customer_care_label_10 }}</a></li>
            {% endif %}
          </ul>
        </nav>
      </div>

      <div class="custom-footer__column">
        {% if about_heading != blank %}
          <h2 class="custom-footer__heading">{{ about_heading }}</h2>
        {% endif %}
        <nav
          class="custom-footer__nav"
          aria-label="{{ about_heading | escape }}"
        >
          <ul class="custom-footer__menu" role="list">
            {% if section.settings.about_label_1 != blank %}
              <li><a href="{{ section.settings.about_url_1 | default: '#' }}">{{ section.settings.about_label_1 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_2 != blank %}
              <li><a href="{{ section.settings.about_url_2 | default: '#' }}">{{ section.settings.about_label_2 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_3 != blank %}
              <li><a href="{{ section.settings.about_url_3 | default: '#' }}">{{ section.settings.about_label_3 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_4 != blank %}
              <li><a href="{{ section.settings.about_url_4 | default: '#' }}">{{ section.settings.about_label_4 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_5 != blank %}
              <li><a href="{{ section.settings.about_url_5 | default: '#' }}">{{ section.settings.about_label_5 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_6 != blank %}
              <li><a href="{{ section.settings.about_url_6 | default: '#' }}">{{ section.settings.about_label_6 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_7 != blank %}
              <li><a href="{{ section.settings.about_url_7 | default: '#' }}">{{ section.settings.about_label_7 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_8 != blank %}
              <li><a href="{{ section.settings.about_url_8 | default: '#' }}">{{ section.settings.about_label_8 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_9 != blank %}
              <li><a href="{{ section.settings.about_url_9 | default: '#' }}">{{ section.settings.about_label_9 }}</a></li>
            {% endif %}
            {% if section.settings.about_label_10 != blank %}
              <li><a href="{{ section.settings.about_url_10 | default: '#' }}">{{ section.settings.about_label_10 }}</a></li>
            {% endif %}
          </ul>
        </nav>
      </div>

      <div class="custom-footer__column">
        {% if app_heading != blank %}
          <h2 class="custom-footer__heading">{{ app_heading }}</h2>
        {% endif %}
        <div class="custom-footer__app">
          {% if section.settings.qr_image != blank %}
            <div class="custom-footer__qr">
              {{
                section.settings.qr_image
                | image_url: width: 600
                | image_tag:
                  widths: '160, 240, 320, 480, 600',
                  sizes: '(max-width: 749px) min(180px, 50vw), 220px',
                  class: 'custom-footer__qr-image',
                  alt: app_heading
              }}
            </div>
          {% endif %}

          {% if section.settings.app_description != blank %}
            <div class="custom-footer__description rte">
              {{ section.settings.app_description }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="custom-footer__column">
        {% if payments_heading != blank %}
          <h2 class="custom-footer__heading">{{ payments_heading }}</h2>
        {% endif %}

        <ul class="custom-footer__payments" role="list">
          {% if section.settings.show_mastercard %}
            <li class="custom-footer__payment-item">
              {{ 'master' | payment_type_svg_tag: class: 'icon icon--full-color custom-footer__payment-icon' }}
            </li>
          {% endif %}
          {% if section.settings.show_visa %}
            <li class="custom-footer__payment-item">
              {{ 'visa' | payment_type_svg_tag: class: 'icon icon--full-color custom-footer__payment-icon' }}
            </li>
          {% endif %}
          {% if section.settings.show_amex %}
            <li class="custom-footer__payment-item">
              {{ 'american_express' | payment_type_svg_tag: class: 'icon icon--full-color custom-footer__payment-icon' }}
            </li>
          {% endif %}
          {% if section.settings.show_jcb %}
            <li class="custom-footer__payment-item">
              {{ 'jcb' | payment_type_svg_tag: class: 'icon icon--full-color custom-footer__payment-icon' }}
            </li>
          {% endif %}
          {% if section.settings.show_unionpay %}
            <li class="custom-footer__payment-item">
              {{ 'unionpay' | payment_type_svg_tag: class: 'icon icon--full-color custom-footer__payment-icon' }}
            </li>
          {% endif %}
          {% if section.settings.show_apple_pay %}
            <li class="custom-footer__payment-item">
              {{ 'apple_pay' | payment_type_svg_tag: class: 'icon icon--full-color custom-footer__payment-icon' }}
            </li>
          {% endif %}
        </ul>
      </div>
    </div>

    <div class="custom-footer__separator" aria-hidden="true"></div>

    <div class="custom-footer__brand">
      {% if brand_heading != blank %}
        <h2 class="custom-footer__brand-heading">{{ brand_heading }}</h2>
      {% endif %}

      {% if brand_description != blank %}
        <div class="custom-footer__brand-description rte">
          {{ brand_description }}
        </div>
      {% endif %}

      {% if section.settings.brand_link_text != blank %}
        <a
          class="custom-footer__brand-link"
          href="{{ section.settings.brand_link_url | default: '#' }}"
        >
          {{ section.settings.brand_link_text }}
        </a>
      {% endif %}
    </div>

    <div class="custom-footer__separator" aria-hidden="true"></div>

    <div class="custom-footer__copyright">
      {% if section.settings.footer_logo != blank %}
        <div class="custom-footer__copyright-logo">
          {{
            section.settings.footer_logo
            | image_url: width: 400
            | image_tag:
              widths: '100, 140, 180, 240, 320, 400',
              sizes: '160px',
              class: 'custom-footer__copyright-image',
              alt: brand_heading
          }}
        </div>
      {% endif %}

      {% if copyright_text != blank %}
        <p class="custom-footer__copyright-text">{{ copyright_text }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .custom-footer {
    background: var(--custom-footer-background);
    color: var(--custom-footer-text);
  }

  .custom-footer,
  .custom-footer p,
  .custom-footer li,
  .custom-footer a {
    color: var(--custom-footer-text);
  }

  .custom-footer__inner {
    padding-top: var(--custom-footer-top-padding);
    padding-bottom: var(--custom-footer-bottom-padding);
    padding-inline: clamp(20px, 3vw, 32px);
  }

  .custom-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--custom-footer-mobile-gap);
  }

  .custom-footer__column {
    min-width: 0;
  }

  .custom-footer__heading,
  .custom-footer__brand-heading {
    margin: 0 0 1.5rem;
    color: var(--custom-footer-heading);
    font-size: var(--custom-footer-heading-size);
    line-height: 1.25;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .custom-footer__menu,
  .custom-footer__payments {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .custom-footer__menu {
    display: grid;
    gap: 0.875rem;
  }

  .custom-footer__menu a,
  .custom-footer__brand-link {
    color: var(--custom-footer-link);
    font-size: var(--custom-footer-menu-size);
    line-height: 1.5;
    text-decoration: none;
    transition: color 0.25s ease, text-decoration-color 0.25s ease;
    text-underline-offset: 0.18em;
  }

  .custom-footer__menu a:hover,
  .custom-footer__brand-link:hover {
    color: var(--custom-footer-link-hover);
    text-decoration: underline;
  }

  .custom-footer__app {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .custom-footer__qr {
    flex: 0 0 auto;
    width: min(100%, var(--custom-footer-qr-width));
  }

  .custom-footer__qr-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .custom-footer__description,
  .custom-footer__brand-description {
    font-size: var(--custom-footer-description-size);
    line-height: 1.65;
  }

  .custom-footer__description > *:first-child,
  .custom-footer__brand-description > *:first-child {
    margin-top: 0;
  }

  .custom-footer__description > *:last-child,
  .custom-footer__brand-description > *:last-child {
    margin-bottom: 0;
  }

  .custom-footer__payments {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .custom-footer__payment-item {
    display: inline-flex;
    align-items: center;
  }

  .custom-footer__payment-icon {
    display: block;
  }

  .custom-footer__separator {
    width: 100%;
    height: 1px;
    background: rgb(0 0 0 / 0.12);
    margin-block: clamp(2rem, 4vw, 3rem);
  }

  .custom-footer__brand {
    max-width: 56rem;
  }

  .custom-footer__brand-link {
    display: inline-block;
    margin-top: 1rem;
  }

  .custom-footer__copyright {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-align: center;
  }

  .custom-footer__copyright-logo {
    width: min(100%, var(--custom-footer-logo-width));
  }

  .custom-footer__copyright-image {
    display: block;
    width: 100%;
    height: auto;
    margin: 0 auto;
  }

  .custom-footer__copyright-text {
    margin: 0;
    font-size: var(--custom-footer-copyright-size);
    line-height: 1.5;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: calc(var(--custom-footer-mobile-gap) * 1.25);
      column-gap: var(--custom-footer-column-gap);
    }
  }

  @media screen and (min-width: 990px) {
    .custom-footer__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .custom-footer__inner {
      text-align: center;
    }

    .custom-footer__app {
      flex-direction: column;
      align-items: center;
    }

    .custom-footer__payments {
      justify-content: center;
    }

    .custom-footer__brand {
      margin-inline: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
